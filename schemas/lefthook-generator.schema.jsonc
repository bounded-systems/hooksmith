          "$ref": "#/definitions/option<list<string>>,"
        },
        "only-dirs-changed": {
          "$ref": "#/definitions/option<list<string>>,"
        },
        "only-emails": {
          "$ref": "#/definitions/option<list<string>>,"
        },
        "only-extensions": {
          "$ref": "#/definitions/option<list<string>>,"
        },
        "only-extensions-changed": {
          "$ref": "#/definitions/option<list<string>>,"
        },
        "only-files": {
          "$ref": "#/definitions/option<list<string>>,"
        },
        "only-files-changed": {
          "$ref": "#/definitions/option<list<string>>,"
        },
        "only-messages": {
          "$ref": "#/definitions/option<list<string>>,"
        },
        "only-patterns": {
          "$ref": "#/definitions/option<list<string>>,"
        },
        "only-patterns-changed": {
          "$ref": "#/definitions/option<list<string>>,"
        },
        "only-staged": {
          "$ref": "#/definitions/option<bool>,"
        },
        "only-tags": {
          "$ref": "#/definitions/option<list<string>>,"
        },
        "parallel": {
          "$ref": "#/definitions/option<bool>,"
        },
        "skip-output": {
          "$ref": "#/definitions/option<bool>,"
        },
        "stop-on-failure": {
          "$ref": "#/definitions/option<bool>,"

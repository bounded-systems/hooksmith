          "$ref": "#/definitions/string,"
        },
        "priority": {
          "$ref": "#/definitions/option<u32>,"
        },
        "skip": {
          "$ref": "#/definitions/list<skip-condition>,"
        },
        "stage": {
          "$ref": "#/definitions/option<string>,"
        },
        "tags": {
          "$ref": "#/definitions/list<string>,"
        },
        "timeout": {
          "$ref": "#/definitions/option<u32>,"
        },
        "working-dir": {
          "$ref": "#/definitions/option<string>,"
        }
      },
      "required": [
        "name",
        "hook-type",
        "command",
        "enabled",
        "description",
        "tags",
        "stage",
        "priority",
        "timeout",
        "working-dir",
        "env",
        "depends-on",
        "skip"
      ],
      "type": "object"
    },
    "hook-type-info": {
      "additionalProperties": false,
      "properties": {
        "description": {
          "$ref": "#/definitions/string,"
        },
        "documentation": {
          "$ref": "#/definitions/option<string>,"
        },
        "examples": {
          "$ref": "#/definitions/list<string>,"
        },
        "name": {
          "$ref": "#/definitions/string,"
        },
        "stage": {
          "$ref": "#/definitions/string,"
        },
        "triggers": {
          "$ref": "#/definitions/list<string>,"
        }
      },
      "required": [
        "name",
        "description",
        "stage",
        "triggers",
        "examples",
        "documentation"
      ],

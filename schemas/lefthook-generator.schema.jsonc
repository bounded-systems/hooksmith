        "only-files",
        "only-dirs",
        "only-extensions",
        "only-patterns",
        "only-branches",
        "only-tags",
        "only-commits",
        "only-authors",
        "only-emails",
        "only-messages",
        "only-files-changed",
        "only-dirs-changed",
        "only-extensions-changed",
        "only-patterns-changed"

{
  "$id": "https://hooksmith.dev/schemas/lefthook-generator.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "env-var": {
      "additionalProperties": false,
      "properties": {
        "name": {
          "$ref": "#/definitions/string,"
        },
        "value": {
          "$ref": "#/definitions/string,"
        }
      },
      "required": [
        "name",
        "value"
      ],
      "type": "object"
    },
    "git-info": {
      "additionalProperties": false,
      "properties": {
        "current-branch": {
          "$ref": "#/definitions/option<string>,"
        },
        "default-branch": {
          "$ref": "#/definitions/option<string>,"
        },
        "git-version": {
          "$ref": "#/definitions/option<string>,"
        },
        "is-bare": {
          "$ref": "#/definitions/option<bool>,"
        },
        "is-shallow": {
          "$ref": "#/definitions/option<bool>,"
        },
        "repo-name": {
          "$ref": "#/definitions/option<string>,"
        },
        "repo-root": {
          "$ref": "#/definitions/option<string>,"
        },
        "repo-url": {
          "$ref": "#/definitions/option<string>,"
        }
      },
      "required": [
        "repo-url",
        "repo-name",
        "default-branch",
        "current-branch",
        "repo-root",
        "git-version",
        "is-bare",
        "is-shallow"
      ],
      "type": "object"
    },
    "global-settings": {

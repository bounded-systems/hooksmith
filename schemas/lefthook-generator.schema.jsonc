      "type": "object"
    },
    "skip-condition": {
      "additionalProperties": false,
      "properties": {
        "condition-type": {
          "$ref": "#/definitions/skip-condition-type,"
        },
        "description": {
          "$ref": "#/definitions/option<string>,"
        },
        "value": {
          "$ref": "#/definitions/string,"
        }
      },
      "required": [
        "condition-type",
        "value",
        "description"
      ],
      "type": "object"
    },
    "skip-condition-type": {
      "enum": [
        "file-pattern",
        "branch-pattern",
        "commit-message",
        "merge-commit",
        "no-files-changed",
        "files-changed",
        "env-var",
        "command"
      ],
      "type": "string"
    },
    "validation-config": {
      "additionalProperties": false,
      "properties": {
        "config-content": {
          "$ref": "#/definitions/string,"
        },
        "schema": {
          "$ref": "#/definitions/option<string>,"
        },
        "validate-commands": {
          "$ref": "#/definitions/bool,"
        },
        "validate-hooks": {
          "$ref": "#/definitions/bool,"
        },
        "validate-schema": {
          "$ref": "#/definitions/bool,"
        },
        "validate-syntax": {
          "$ref": "#/definitions/bool,"
        }
      },
      "required": [
        "config-content",
        "schema",
        "validate-syntax",
        "validate-schema",
        "validate-hooks",
        "validate-commands"
      ],
      "type": "object"
    },
    "validation-error": {
      "additionalProperties": false,
      "properties": {
        "code": {
          "$ref": "#/definitions/option<string>,"
        },
        "location": {
          "$ref": "#/definitions/option<string>,"
        },
        "message": {
          "$ref": "#/definitions/string,"
        },
        "suggestion": {
          "$ref": "#/definitions/option<string>,"
        }
      },
      "required": [
        "message",
        "location",
        "code",
        "suggestion"
      ],
      "type": "object"
    },
    "validation-info": {
      "additionalProperties": false,
      "properties": {
        "code": {
          "$ref": "#/definitions/option<string>,"
        },
        "location": {
          "$ref": "#/definitions/option<string>,"
        },
        "message": {
          "$ref": "#/definitions/string,"
        }
      },
      "required": [
        "message",
        "location",
        "code"
      ],
      "type": "object"
    },
    "validation-result": {
      "additionalProperties": false,
      "properties": {
        "duration-ms": {
          "$ref": "#/definitions/u64,"
        },
        "errors": {
          "$ref": "#/definitions/list<validation-error>,"
        },
        "info": {
          "$ref": "#/definitions/list<validation-info>,"
        },
        "success": {
          "$ref": "#/definitions/bool,"
        },
        "warnings": {
          "$ref": "#/definitions/list<validation-warning>,"
        }
      },
      "required": [
        "success",
        "errors",
        "warnings",
        "info",
        "duration-ms"
      ],
      "type": "object"
    },
    "validation-warning": {
      "additionalProperties": false,
      "properties": {
        "code": {
          "$ref": "#/definitions/option<string>,"
        },
        "location": {
          "$ref": "#/definitions/option<string>,"
        },
        "message": {
          "$ref": "#/definitions/string,"
        },
        "suggestion": {
          "$ref": "#/definitions/option<string>,"
        }
      },
      "required": [
        "message",
        "location",
        "code",
        "suggestion"
      ],
      "type": "object"
    }
  },
  "description": "Schema for the lefthook-generator WIT component interface",
  "title": "Lefthook Generator Component Schema",
  "type": "object"
}
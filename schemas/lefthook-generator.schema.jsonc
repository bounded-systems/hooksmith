    "lefthook-config": {
      "additionalProperties": false,
      "properties": {
        "git-info": {
          "$ref": "#/definitions/git-info,"
        },
        "global-settings": {
          "$ref": "#/definitions/global-settings,"
        },
        "hooks": {
          "$ref": "#/definitions/list<hook-config>,"

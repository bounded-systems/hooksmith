        },
        "strict-mode": {
          "$ref": "#/definitions/bool,"
        },
        "validate-schema": {
          "$ref": "#/definitions/bool,"
        }
      },
      "required": [
        "output-path",
        "hooks",
        "validate-schema",
        "global-settings",
        "git-info",
        "include-comments",
        "strict-mode"
      ],
      "type": "object"
    },
    "lefthook-result": {
      "additionalProperties": false,
      "properties": {
        "config-content": {
          "$ref": "#/definitions/option<string>,"
        },
        "duration-ms": {
          "$ref": "#/definitions/u64,"
        },
        "error": {
          "$ref": "#/definitions/option<string>,"
        },
        "hooks-count": {
          "$ref": "#/definitions/u32,"
        },
        "output-path": {
          "$ref": "#/definitions/option<string>,"
        },
        "success": {
          "$ref": "#/definitions/bool,"
        },
        "validation-errors": {
          "$ref": "#/definitions/list<string>,"
        },
        "validation-warnings": {
          "$ref": "#/definitions/list<string>,"
        }

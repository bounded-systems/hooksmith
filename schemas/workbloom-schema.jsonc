{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://hooksmith.dev/schemas/workbloom-schema.json",
  "title": "Workbloom Configuration Schema",
  "description": "Schema for .workbloom configuration files used in Hooksmith worktree management",
  "type": "object",
  "properties": {
    "copy_files": {
      "type": "array",
      "description": "Files and directories to automatically copy to new worktrees",
      "items": {
        "type": "string",
        "description": "File or directory path relative to the root repository"
      },
      "default": [
        ".env",
        ".envrc",
        ".env.local",
        ".env.example",
        "hooksmith.toml",
        ".worktree-config.jsonc",
        ".worktree-config.json",
        ".vscode/settings.json",
        ".vscode/launch.json",
        ".vscode/extensions.json",
        ".claude/settings.json",
        ".config/my-settings.json",
        "spin.toml",
        "spin.toml.example",
        ".cargo/config.toml",
        ".cargo/config",
        ".gitignore",
        ".gitattributes",
        "README.md",
        "docs/",
        "scripts/",
        "tools/",
        "secrets/",
        "local/",
        ".cursor/"
      ]
    },
    "auto_shell": {
      "type": "boolean",
      "description": "Whether to automatically open a shell in the new worktree",
      "default": true
    },
    "labels": {
      "type": "array",
      "description": "Semantic labels for this worktree environment",
      "items": {
        "type": "string",
        "enum": [
          "feature",
          "bugfix",
          "hotfix",
          "development",
          "maintenance",
          "urgent",
          "spin",
          "integration",
          "testing",
          "documentation",
          "refactoring",
          "performance",
          "security"
        ]
      }
    },
    "description": {
      "type": "string",
      "description": "Human-readable description of this worktree's purpose"
    },
    "remove_on_cleanup": {
      "type": "array",
      "description": "Files and directories to automatically remove during cleanup",
      "items": {
        "type": "string"
      },
      "default": [
        "tmp/",
        "target/",
        ".DS_Store",
        "*.log",
        "node_modules/",
        ".cache/"
      ]
    },
    "port_allocation": {
      "type": "object",
      "description": "Port allocation configuration for local development",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Whether to enable automatic port allocation",
          "default": true
        },
        "base_port": {
          "type": "integer",
          "description": "Base port number for allocation",
          "minimum": 1024,
          "maximum": 65535,
          "default": 3000
        },
        "services": {
          "type": "object",
          "description": "Service-specific port mappings",
          "additionalProperties": {
            "type": "integer",
            "minimum": 1024,
            "maximum": 65535
          }
        }
      }
    },
    "environment": {
      "type": "object",
      "description": "Environment-specific configuration",
      "properties": {
        "variables": {
          "type": "object",
          "description": "Environment variables to set in worktree",
          "additionalProperties": {
            "type": "string"
          }
        },
        "files": {
          "type": "array",
          "description": "Environment files to source",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "cursor_integration": {
      "type": "object",
      "description": "Cursor IDE integration settings",
      "properties": {
        "auto_open": {
          "type": "boolean",
          "description": "Automatically open worktree in Cursor",
          "default": true
        },
        "project_config": {
          "type": "string",
          "description": "Path to Cursor project configuration template"
        },
        "extensions": {
          "type": "array",
          "description": "Cursor extensions to enable for this worktree",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "setup_commands": {
      "type": "array",
      "description": "Commands to run after worktree creation",
      "items": {
        "type": "string"
      },
      "default": [
        "cargo build",
        "cargo xtask gen-all --validate"
      ]
    },
    "hooks": {
      "type": "object",
      "description": "Lifecycle hooks for worktree operations",
      "properties": {
        "post_create": {
          "type": "array",
          "description": "Commands to run after worktree creation",
          "items": {
            "type": "string"
          }
        },
        "pre_remove": {
          "type": "array",
          "description": "Commands to run before worktree removal",
          "items": {
            "type": "string"
          }
        },
        "post_switch": {
          "type": "array",
          "description": "Commands to run after switching to worktree",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "metadata": {
      "type": "object",
      "description": "Additional metadata for the worktree",
      "properties": {
        "created": {
          "type": "string",
          "format": "date-time",
          "description": "Creation timestamp"
        },
        "author": {
          "type": "string",
          "description": "Worktree creator"
        },
        "purpose": {
          "type": "string",
          "description": "Purpose of this worktree"
        },
        "estimated_duration": {
          "type": "string",
          "description": "Estimated duration for this worktree"
        },
        "dependencies": {
          "type": "array",
          "description": "Dependencies on other worktrees or branches",
          "items": {
            "type": "string"
          }
        }
      }
    }
  },
  "additionalProperties": false,
  "examples": [
    {
      "copy_files": [
        ".env",
        ".envrc",
        "config/dev.toml"
      ],
      "auto_shell": true,
      "labels": ["spin", "integration"],
      "description": "Hooksmith Spin Integration Testbed",
      "remove_on_cleanup": ["tmp/", "target/", ".DS_Store"],
      "port_allocation": {
        "enabled": true,
        "base_port": 3000,
        "services": {
          "api": 3001,
          "frontend": 3002,
          "spin": 8080
        }
      },
      "setup_commands": [
        "cargo build",
        "spin build"
      ],
      "cursor_integration": {
        "auto_open": true,
        "extensions": ["rust-analyzer", "wasm-pack"]
      }
    }
  ]
} 
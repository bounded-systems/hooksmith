{
  "path": "lefthook.yml",
  "slug": "lefthook-config",
  "description": "Lefthook configuration with pre-commit hooks",
  "content": "# @generated by xtask gen-files --file-type=yml\n# @checksum: {checksum}\n\n# Enhanced Lefthook configuration with Hooksmith checksum validation\n# This file is automatically generated. Do not edit manually.\n\npre-commit:\n  parallel: true\n  commands:\n    # Code formatting and linting\n    fmt:\n      glob: \"*.rs\"\n      run: cargo fmt --all -- --check\n    \n    clippy:\n      glob: \"*.rs\"\n      run: cargo clippy --all-targets --all-features -- -D warnings\n    \n    # Tests - only run unit tests, skip integration tests for now\n    test:\n      run: cargo test --lib --bins --examples\n\npre-push:\n  parallel: true\n  commands:\n    # Security audit\n    audit:\n      run: cargo audit\n    \n    # Comprehensive checksum validation\n    validate-all-checksums:\n      run: cargo run -p xtask -- validate-checksums --strict\n    \n    # Generated files check\n    check-generated:\n      run: cargo xtask check --strict\n    \n    # Contract validation\n    contract-check:\n      run: cargo xtask contract check --strict\n\ncommit-msg:\n  commands:\n    conventional:\n      run: cargo run -p xtask -- validate-commit-msg --file \"$1\"\n"
} 

{
  "name": "object-names",
  "version": "1.0.0",
  "description": "Contract defining object naming rules for Git tree structures - Hooksmith Repository Variant",
  "$schema": "https://hooksmith.dev/schemas/contract.schema.json",
  "schema": {
    "$ref": "https://hooksmith.dev/schemas/object-names.schema.json"
  },
  "spec": {
    "git": {
      "tree": {
        "objects": {
          "names": {
            "required": [
              ".gitignore"
            ],
            "allowed": [
              ".gitignore",
              ".gitattributes",
              ".gitmodules",
              ".meta",
              "docs",
              "generated",
              "projects",
              "src",
              "tests",
              "tools",
              "wit",
              "Cargo.toml",
              "Cargo.lock",
              "rust-toolchain.toml",
              "rustfmt.toml",
              "clippy.toml",
              "deny.toml",
              "README.md",
              "*.rs",
              "*.md",
              "*.yml",
              "*.yaml",
              "*.json",
              "*.jsonc",
              "*.hcl",
              "*.txt",
              "Dockerfile",
              "docker-compose.yml",
              "docker-bake.hcl",
              "CODEOWNERS",
              "languages.yml",
              "lefthook.yml",
              "build.rs",
              "agreement.json",
              "sha_mapping.txt",
              "*.gitattributes",
              "*.gitignore",
              "config",
              "contracts",
              "contract_snapshots",
              "crates",
              "examples",
              "gen",
              "generated-sources",
              "hooks",
              "schemas",
              "scripts",
              "src",
              "tests",
              "wit",
              "worktree-lifecycle",
              ".cargo",
              ".github",
              ".hooksmith",
              ".trunk",
              ".wb",
              ".workbloom",
              ".worktree-config.json",
              ".worktree-config.jsonc",
              "test-*.rs",
              "test-*.txt",
              "test-*.gitattributes",
              "test_*.rs",
              "test_*.txt",
              "test_*.md",
              "enhanced-contract-validation-results.sarif",
              ".contract_cache",
              ".dockerignore",
              "test-enhanced-gen-files"
            ],
            "rejected": [],
            "ignored": [
              ".DS_Store",
              "Thumbs.db",
              ".idea",
              ".vscode"
            ]
          }
        }
      }
    }
  }
}

{
  "name": "object-names@root-minimal",
  "version": "1.0.0",
  "description": "Monorepo root object policy - orchestrator for repo-wide policy, tooling, and docs",
  "$schema": "https://hooksmith.dev/schemas/contract.schema.json",
  "schema": {
    "$ref": "https://hooksmith.dev/schemas/object-names.schema.json"
  },
  "spec": {
    "git": {
      "tree": {
        "objects": {
          "names": {
            "required": [
              ".gitignore",
              ".hooksmith"
            ],
            "allowed": [
              ".gitignore",
              ".gitattributes",
              ".github",
              ".hooksmith",
              "Cargo.toml",
              "Cargo.lock",
              "README.md",
              "CONTRIBUTING.md",
              "LICENSE",
              "crates",
              "apps",
              "tools",
              "infra",
              "docs",
              "schemas",
              "contracts",
              "examples",
              "tests"
            ],
            "rejected": [
              "*.rs",
              "src",
              "target",
              "*.log"
            ],
            "ignored": [
              ".DS_Store",
              "Thumbs.db",
              ".idea",
              ".vscode"
            ],
            "exceptions": []
          }
        }
      }
    }
  }
}

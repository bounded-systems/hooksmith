#!/usr/bin/env bash
# Automatically load the Nix development environment when entering this directory

if ! has nix_direnv_version || ! nix_direnv_version 3.0.4; then
  source_url "https://raw.githubusercontent.com/nix-community/nix-direnv/3.0.4/direnvrc" "sha256-DzlYZ33mWF/Gs8DDeyjr8mnVmQGx7ASYqA5WlxwvBG4="
fi

# Use the flake for the development environment
use flake

# Load any local environment variables
dotenv_if_exists .env.local

# Set up some useful environment variables for development
export HOOKSMITH_DEV_MODE=1
export RUST_BACKTRACE=1
export CARGO_INCREMENTAL=1

# Add project-specific environment setup
echo "🔨 Hooksmith development environment loaded via Nix"
echo "📚 See WARP.md for development workflows"

{
  "name": "@hooksmith/verbs",
  "version": "0.1.0",
  "description": "VerbSpec surfaces for hooksmith — contract validation + hook engine (CLI + MCP from one typed contract).",
  "type": "module",
  "bin": {
    "hooksmith-validate": "cli.mjs",
    "hooksmith-hooks": "cli.mjs"
  },
  "scripts": {
    "build:contract-wasm": "cargo build --target wasm32-wasip2 -p contract-validator --release --manifest-path ../Cargo.toml",
    "build:contract-jco": "jco transpile ../target/wasm32-wasip2/release/contract_validator.wasm --wit ../crates/components/contract-validator/wit/ -o dist/contract-validator/ --map 'hooksmith:contract-validator/contract-validator=./contract-validator.js'",
    "build:hook-wasm": "cargo build --target wasm32-wasip2 -p hook-engine --release --manifest-path ../Cargo.toml",
    "build:hook-jco": "jco transpile ../target/wasm32-wasip2/release/hook_engine.wasm --wit ../crates/components/hook-engine/wit/ -o dist/hook-engine/ --map 'hooksmith:engine/hook-engine=./hook-engine.js'",
    "build:contract": "npm run build:contract-wasm && npm run build:contract-jco",
    "build:hook-engine": "npm run build:hook-wasm && npm run build:hook-jco",
    "build": "npm run build:contract && npm run build:hook-engine",
    "test": "node test.mjs",
    "mcp": "node mcp.mjs"
  },
  "dependencies": {
    "@bounded-systems/verbspec": "npm:@jsr/bounded-systems__verbspec@^0.3.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@bytecodealliance/jco": "^1.0.0"
  }
}

# Git and version control
.git/
.gitignore
.gitattributes

# Rust build artifacts
target/
Cargo.lock

# Documentation and development files
docs/
*.md
README*

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo

# OS generated files
.DS_Store
Thumbs.db

# Test files and temporary data
test_*
*.tmp

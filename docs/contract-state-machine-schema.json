{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Contract State Machine Schema",
  "description": "Schema-driven state machine for hierarchical contract validation with proof mechanisms",
  "type": "object",
  "definitions": {
    "ContractState": {
      "type": "string",
      "enum": ["UNTRACKED", "UNVALIDATED", "VALIDATED", "LOCKED"],
      "description": "Valid states in the contract validation lifecycle"
    },
    "TransitionEvent": {
      "type": "string",
      "enum": [
        "detect_contract",
        "validate_contract", 
        "lock_contract",
        "modify_contract",
        "regen_codegen",
        "release_proof"
      ],
      "description": "Valid transition events that can change contract state"
    },
    "ValidationScope": {
      "type": "string",
      "enum": ["char", "line", "chunk", "file", "dir", "repo"],
      "description": "Hierarchical validation scopes from smallest to largest"
    },
    "HashPattern": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$",
      "description": "SHA256 hash with prefix"
    }
  },
  "properties": {
    "file": {
      "type": "string",
      "description": "Path to the file being validated"
    },
    "contract": {
      "type": "string",
      "description": "Type of contract (e.g., 'wit', 'wasm', 'codegen', 'validation')"
    },
    "state": {
      "$ref": "#/definitions/ContractState"
    },
    "scope": {
      "$ref": "#/definitions/ValidationScope",
      "description": "Validation scope level for this contract"
    },
    "hash": {
      "$ref": "#/definitions/HashPattern",
      "description": "Content hash of the validated artifact"
    },
    "validated_by": {
      "type": "string",
      "description": "Tool and version that performed validation"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of validation"
    },
    "parent_scope": {
      "$ref": "#/definitions/ValidationScope",
      "description": "Parent scope in the hierarchical validation chain"
    },
    "parent_hash": {
      "$ref": "#/definitions/HashPattern",
      "description": "Hash of the parent scope for Merkle chain verification"
    },
    "child_scopes": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "scope": { "$ref": "#/definitions/ValidationScope" },
          "hash": { "$ref": "#/definitions/HashPattern" },
          "file": { "type": "string" }
        },
        "required": ["scope", "hash", "file"]
      },
      "description": "Child scope hashes for Merkle tree construction"
    },
    "validation_errors": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "message": { "type": "string" },
          "line": { "type": "integer" },
          "column": { "type": "integer" },
          "severity": {
            "type": "string",
            "enum": ["error", "warning", "info"]
          }
        },
        "required": ["message", "severity"]
      },
      "description": "Validation errors if state is UNVALIDATED"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "description": "Additional metadata for the contract"
    }
  },
  "required": ["file", "contract", "state", "scope", "hash", "validated_by", "timestamp"],
  "examples": [
    {
      "file": "src/modules/wasm.rs",
      "contract": "validation",
      "state": "VALIDATED",
      "scope": "file",
      "hash": "sha256:a1b2c3d4e5f6789012345678901234567890abcdef1234567890abcdef123456",
      "validated_by": "xtask-contract-validate 0.2.0",
      "timestamp": "2025-01-02T15:20:00Z",
      "parent_scope": "dir",
      "parent_hash": "sha256:fedcba0987654321098765432109876543210fedcba0987654321098765432109",
      "child_scopes": [
        {
          "scope": "line",
          "hash": "sha256:1234567890abcdef1234567890abcdef1234567890abcdef1234567890abcdef12",
          "file": "src/modules/wasm.rs:1-50"
        }
      ]
    }
  ]
} 

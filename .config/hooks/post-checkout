#!/bin/sh

# Post-checkout hook stub that calls the Rust binary
# This hook calls the post-checkout binary from the hooks crate

# Get the directory where this script is located
HOOK_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_ROOT="$(cd "$HOOK_DIR/../.." && pwd)"

# Call the Rust post-checkout binary
exec "$PROJECT_ROOT/target/debug/post-checkout" "$@"

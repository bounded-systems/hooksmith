#!/bin/sh

# Hook stub that calls the Rust binary
# This hook calls the binary from the main crate

# Get the project root using git rev-parse (works for worktrees)
PROJECT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)"

# Fallback to old method if git rev-parse fails
if [ -z "$PROJECT_ROOT" ]; then
    HOOK_DIR="$(cd "$(dirname "$0")" && pwd)"
    PROJECT_ROOT="$(cd "$HOOK_DIR/../.." && pwd)"
fi

# Call the Rust binary
exec "$PROJECT_ROOT/target/debug/$(basename "$0")" "$@"

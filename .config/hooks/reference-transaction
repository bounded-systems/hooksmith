#!/bin/sh

# Reference-transaction hook stub that calls the Rust binary
# This hook calls the reference-transaction binary from the hooks crate

# Get the directory where this script is located
HOOK_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_ROOT="$(cd "$HOOK_DIR/../.." && pwd)"

# Call the Rust reference-transaction binary
exec "$PROJECT_ROOT/target/debug/reference-transaction" "$@"
